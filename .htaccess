# RobTop — корень клона репозитория на сервере (robtop/).
# Раскладка: вебхук Hostinger Git кладёт сюда ВЕСЬ репозиторий, приложение живёт в app/
# и открывается по адресу /robtop/app/. Этот файл закрывает служебные файлы от публичного
# доступа и ведёт с корня в приложение. Публикуется как robtop/.htaccess.

Options -Indexes
AddDefaultCharset UTF-8

# Документация и схема БД закрыты: КОНТЕКСТ.md, РЕЛИЗ.md, ПЛАН*.md, README.md, schema.sql, миграции.
<FilesMatch "\.(md|sql)$">
  Require all denied
</FilesMatch>

# Дотфайлы закрыты (.gitignore, .DS_Store и т.п.). .htaccess Apache не отдаёт и сам.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Служебные папки git недоступны целиком.
  RewriteRule (^|/)\.(git|github)(/|$) - [F]

  # Корень ведёт в приложение: /robtop/ → /robtop/app/
  # 302, а не 301: если позже переедем на deploy-ветку и чистый /robtop/, редирект не закэшируется.
  RewriteRule ^$ app/ [R=302,L]

  # Короткие ссылки: /robtop/i/<КОД> — приглашение, /robtop/r/<КОД> — сброс пароля.
  # Именно РЕДИРЕКТ (302), не внутренний rewrite: family.html грузит api/ по относительным
  # путям, при внутреннем rewrite браузер остался бы на /i/... и пути бы сломались.
  RewriteRule ^i/([A-Za-z0-9]{4,64})$ app/family.html?invite=$1 [R=302,L]
  RewriteRule ^r/([A-Za-z0-9]{4,64})$ app/family.html?reset=$1 [R=302,L]

  # Публичный виш-лист: /robtop/w/<ник> → app/w.html?u=<ник>.
  # Ник может быть кириллицей/с пробелами: флаг B заново кодирует $1 в query string.
  # Лимит в БАЙТАХ декодированного пути (24 кириллических символа = 48 байт) — поэтому 128.
  RewriteRule ^w/([^/]{2,128})$ app/w.html?u=$1 [R=302,L,B]
</IfModule>

# RobTop — папка приложений, установленных в РАНТАЙМЕ (вне Git, переживает деплой).
# Жёсткое правило безопасности: установленные модули — только статика.
# Никакого выполнения серверного кода из этой папки.
Options -Indexes
<FilesMatch "\.(php|phtml|phar|php[0-9]?|cgi|pl|py|sh|fcgi|pht)$">
  Require all denied
</FilesMatch>

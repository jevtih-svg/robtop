# RobTop — Apache (Hostinger). Публикуется как robtop/.htaccess
# Приложение открывается по «корневому» пути:  <домен>/robtop/
# (например apps.tilley.live/robtop). Зависит только от пути /robtop, не от домена.

Options -Indexes
DirectoryIndex index.html
AddDefaultCharset UTF-8

# ===== Доступ к приложению по пути /robtop (SPA-маршрутизация) =====
# index.html отдаётся на корне папки (DirectoryIndex). Дополнительно:
# реальные файлы/папки (api/*.php, assets/, uploads/, картинки) отдаём как есть,
# а любой другой под-путь под /robtop отправляем на index.html — чтобы
# приложение открывалось и не было 404 на под-адресах.
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Базовый путь приложения. Раскладка вебхука Hostinger Git: в robtop/ лежит весь
  # репозиторий, приложение в robtop/app/ → база /robtop/app/.
  # Если приложение снова окажется прямо в /robtop/ (deploy-ветка), поменяй здесь.
  RewriteBase /robtop/app/

  # Существующие файлы и папки — напрямую (API, ассеты, загрузки)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # API не трогаем
  RewriteRule ^api/ - [L]

  # Всё остальное — на главную страницу приложения
  RewriteRule ^ index.html [L]
</IfModule>

# ===== Безопасность =====
# Не отдавать конфиг и внутренние include-файлы API наружу
<FilesMatch "^config.*\.php$">
  Require all denied
</FilesMatch>
<FilesMatch "^_.*\.php$">
  Require all denied
</FilesMatch>

# ===== Кэш статики (по желанию) =====
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png      "access plus 7 days"
  ExpiresByType image/jpeg     "access plus 7 days"
  ExpiresByType image/svg+xml  "access plus 7 days"
  ExpiresByType image/webp     "access plus 7 days"
</IfModule>

# ===== Принудительный HTTPS (SEC 2026-06-09: включён) =====
# X-Forwarded-Proto — чтобы не зациклиться за SSL-терминирующим прокси (LiteSpeed/Hostinger).
<IfModule mod_rewrite.c>
  RewriteCond %{HTTPS} off
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
</IfModule>

# ВЕСЬ HTML и манифест — без кэша без перепроверки (2026-06-07): прод отдавал
# по явному адресу app/index.html копию ДВУХДНЕВНОЙ давности (v2026.06.05.9 при
# актуальной v2026.06.07.37 на адресе каталога) — кэш LiteSpeed/браузера держит
# «директорию» и «/index.html» как разные записи, и устройства с закладкой или
# иконкой «на домашний экран» залипали на старом приложении («не вижу заданий»,
# «очки не доходят»). HTML без ?v= кэшировать нельзя; JS/CSS обновляются сами —
# их URL несут ?v=<версия> из index.html. no-cache (не no-store): браузер хранит,
# но ВСЕГДА перепроверяет у сервера.
<IfModule mod_headers.c>
  <FilesMatch "\.(html|webmanifest)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  # SEC 2026-06-09: заголовки безопасности. Кадрирование запрещено (кликджекинг), MIME-sniffing off.
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "DENY"
  Header always set Referrer-Policy "same-origin"
  # CSP: ресурсы только свои + Google Fonts (index.html их грузит). Inline-скрипт/стиль разрешён
  # ('unsafe-inline') — в index.html есть инлайны; ужесточить до nonce можно позже. Фрейминг и
  # плагины запрещены. Картинки — свои + data: (превью с canvas).
  <FilesMatch "\.html$">
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
  </FilesMatch>
</IfModule>

# Серверный кэш LiteSpeed (Hostinger) для приложения выключаем целиком:
# сайт семейный, нагрузки нет — корректность важнее скорости отдачи.
<IfModule LiteSpeed>
  CacheDisable public /
</IfModule>

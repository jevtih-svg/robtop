# RobTop — Apache (Hostinger)
Options -Indexes
DirectoryIndex index.html
AddDefaultCharset UTF-8

# Не отдавать конфиг и внутренние include-файлы API наружу
<FilesMatch "^config.*\.php$">
  Require all denied
</FilesMatch>
<FilesMatch "^_.*\.php$">
  Require all denied
</FilesMatch>

# Кэш статики (по желанию)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png  "access plus 7 days"
  ExpiresByType image/jpeg "access plus 7 days"
</IfModule>

# При необходимости можно включить принудительный HTTPS:
# <IfModule mod_rewrite.c>
#   RewriteEngine On
#   RewriteCond %{HTTPS} off
#   RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
# </IfModule>

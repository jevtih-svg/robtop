# Production configuration
config.php
**/config.php

# Медиа вне Git — живут на сервере, заливаются по FTP, переживают деплой.
# Графика приложения (иконки, логотипы, иллюстрации):
media/
app/media/
**/media/
# Пользовательские файлы (фото желаний и т.п.):
uploads/
app/uploads/
**/uploads/
storage/
cache/
logs/

# Приложения, установленные в РАНТАЙМЕ через магазин — вне Git, переживают деплой.
# Версионируем только защиту папки и образцы каталога.
app/apps/*
!app/apps/.htaccess
!app/apps/_catalog/
!app/apps/_catalog/**

# Deployment
.ftp-deploy-sync-state.json

# System
.DS_Store
Thumbs.db
*.log
node_modules/
